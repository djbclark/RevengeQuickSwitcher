{
  "name": "revenge-quick-switcher",
  "version": "4.4.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --minify --format=esm --external:react --external:react-native --external:@revenge-mod --external:@revenge-mod/* --outfile=dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "verify": "npm run typecheck && npm test && npm run build && node scripts/check-manifest.mjs"
  },
  "author": "Danny Clark",
  "devDependencies": {
    "typescript": "^5.0.0",
    "esbuild": "^0.28.0",
    "vitest": "^3.0.0",
    "@revenge-mod/types": "npm:vendetta-types@2.4.21"
  }
}
